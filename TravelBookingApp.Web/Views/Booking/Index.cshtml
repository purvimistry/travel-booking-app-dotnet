@model IEnumerable<TravelBookingApp.Web.Models.BookingViewModel>
@{
    ViewData["Title"] = "All Bookings";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>All Bookings</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Booking</a>
</div>

<table class="table table-striped table-hover" id="bookingTable">
    <thead class="table-dark">
        <tr>
            <th>#</th>
            <th>Customer</th>
            <th>Hotel</th>
            <th>Check-In</th>
            <th>Check-Out</th>
            <th>Nights</th>
            <th>Amount (INR)</th>
            <th>Amount (USD)</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var b in Model)
        {
            <tr data-id="@b.BookingId" data-amount="@b.TotalAmount">
                <td>@b.BookingId</td>
                <td>
                    @b.CustomerName<br />
                    <small class="text-muted">@b.CustomerEmail</small>
                </td>
                <td>
                    @b.HotelName<br />
                    <small class="text-muted">@b.HotelCity</small>
                </td>
                <td>@b.CheckInDisplay</td>
                <td>@b.CheckOutDisplay</td>
                <td>@b.NumberOfNights</td>
                <td>₹@b.TotalAmount.ToString("N0")</td>
                <td class="usd-amount">
                    <span class="spinner-border spinner-border-sm text-secondary"></span>
                </td>
                <td>
                    <span class="badge @(b.Status == "Confirmed" ? "bg-success" :
                                                                   b.Status == "Cancelled" ? "bg-danger" : "bg-secondary")">
                    @b.Status
                </span>
            </td>
            <td>
                <a asp-action="Details" asp-route-id="@b.BookingId"
                   class="btn btn-sm btn-outline-info">View</a>
                <a asp-action="Edit" asp-route-id="@b.BookingId"
                   class="btn btn-sm btn-outline-warning">Edit</a>
                <button class="btn btn-sm btn-outline-danger delete-btn"
                        data-id="@b.BookingId">
                    Delete
                </button>
            </td>
        </tr>
                }
    </tbody>
</table>

@section Scripts {
    <script>
        $(document).ready(function () {

            // Load USD conversion for every row via Ajax
            $('#bookingTable tbody tr').each(function () {
                var row = $(this);
                var amount = row.data('amount');

                $.ajax({
                    url: 'https://localhost:7065/api/currency/convert',
                    type: 'GET',
                    data: { amount: amount, from: 'INR', to: 'USD' },
                    success: function (res) {
                        row.find('.usd-amount').html('$' + res.convertedAmount.toFixed(2));
                    },
                    error: function () {
                        row.find('.usd-amount').html('<span class="text-muted">N/A</span>');
                    }
                });
            });

            // Delete booking via Ajax
            $(document).on('click', '.delete-btn', function () {
                var id = $(this).data('id');
                if (!confirm('Are you sure you want to delete this booking?')) return;

                $.ajax({
                    url: '/Booking/Delete/' + id,
                    type: 'POST',
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function (res) {
                        if (res.success) {
                            $('tr[data-id="' + id + '"]').fadeOut(400, function () {
                                $(this).remove();
                            });
                        } else {
                            alert(res.message);
                        }
                    },
                    error: function () {
                        alert('Something went wrong. Please try again.');
                    }
                });
            });
        });
    </script>
    @Html.AntiForgeryToken()
}